[Unit]
Description=idesighn.ru Telegram lead bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/idesighn-bot.env
ExecStart=/usr/bin/python3 /opt/idesighn-bot/bot.py
WorkingDirectory=/opt/idesighn-bot
Restart=always
RestartSec=3
User=www-data
Group=www-data
StateDirectory=idesighn-bot
RuntimeMaxSec=infinity
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target
